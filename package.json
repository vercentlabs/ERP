{
  "name": "vercent-erp-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test -- --passWithNoTests",
    "typecheck": "turbo run build",
    "dev": "turbo run dev --parallel",
    "db:local:up": "docker compose -p vercent-erp-local -f infrastructure/docker/compose.local.yml up -d",
    "db:local:down": "docker compose -p vercent-erp-local -f infrastructure/docker/compose.local.yml down",
    "db:local:reset": "tsx scripts/devex/db-local-reset.ts",
    "db:doctor": "tsx scripts/devex/db-doctor.ts",
    "db:migrate:control": "tsx scripts/db/migrate-control-plane.ts",
    "db:migrate:tenant": "tsx scripts/db/migrate-tenant.ts",
    "db:migrate:all": "tsx scripts/db/migrate-all-tenants.ts",
    "db:migrate:control-plane": "tsx scripts/db/migrate-control-plane.ts",
    "db:migrate:tenants": "tsx scripts/db/migrate-all-tenants.ts",
    "db:seed:dev": "tsx scripts/db/seed-tenant-owner.ts",
    "smoke:crm-leads": "tsx scripts/devex/smoke-crm-leads.ts",
    "smoke:crm-opportunities": "tsx scripts/devex/smoke-crm-opportunities.ts",
    "smoke:lead-conversion": "tsx scripts/devex/smoke-lead-conversion.ts",
    "smoke:master-data": "tsx scripts/devex/smoke-master-data.ts",
    "smoke:inventory-stock": "tsx scripts/devex/smoke-inventory-stock.ts",
    "smoke:sales-delivery-notes": "tsx scripts/devex/smoke-sales-delivery-notes.ts",
    "smoke:sales-invoices": "tsx scripts/devex/smoke-sales-invoices.ts",
    "smoke:sales-invoice-accounting": "tsx scripts/devex/smoke-sales-invoice-accounting.ts",
    "smoke:customer-receipts": "tsx scripts/devex/smoke-customer-receipts.ts",
    "smoke:sales-credit-notes": "tsx scripts/devex/smoke-sales-credit-notes.ts",
    "smoke:sales-debit-notes": "tsx scripts/devex/smoke-sales-debit-notes.ts",
    "smoke:customer-refunds": "tsx scripts/devex/smoke-customer-refunds.ts",
    "smoke:bank-reconciliation": "tsx scripts/devex/smoke-bank-reconciliation.ts",
    "smoke:finance-accounting": "tsx scripts/devex/smoke-finance-accounting.ts",
    "smoke:sales-orders": "tsx scripts/devex/smoke-sales-orders.ts",
    "smoke:sales-quotations": "tsx scripts/devex/smoke-sales-quotations.ts",
    "smoke:all": "tsx scripts/devex/smoke-all.ts",
    "standards:check": "tsx scripts/devex/workspace-standards.ts"
  },
  "dependencies": {
    "@types/express": "^4.17.21",
    "@vercent/database": "workspace:*",
    "@vercent/permissions": "workspace:*",
    "@vercent/shared-types": "workspace:*",
    "@vercent/workflows": "workspace:*",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.12.0",
    "redis": "^4.6.14",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "knip": "^5.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "turbo": "^2.0.0",
    "typescript-eslint": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
